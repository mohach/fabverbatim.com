---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import ContactForm from '../../components/ContactForm.astro';
import Footer from '../../components/Footer.astro';
---
<Layout lang="en" title="About Me — Fab Verbatim" description="Meet Fabienne Annys, sworn translator and interpreter with 30+ years of experience, registered in Belgium, Spain and the Netherlands.">
  <Nav lang="en" currentPage="about"/>
  <main>
    <div class="page-hero">
      <div class="page-hero-inner reveal">
        <p class="eyebrow eyebrow--light">Fab Verbatim</p>
        <h1>Sworn and technical translator — Spanish · Catalan · English · Dutch · French</h1>
        <p>Passionate about languages since childhood, with over 30 years of experience and accreditation in three countries.</p>
      </div>
    </div>
    <section class="about-block">
      <div class="ab-img reveal">
        <img src="/fabienne.png" alt="Fabienne Annys"/>
        <div class="ab-creds">
          <div class="ab-cred"><span class="ab-dot"></span>Certified sworn translator in Belgium</div>
          <div class="ab-cred"><span class="ab-dot"></span>Certified sworn translator in Spain</div>
          <div class="ab-cred"><span class="ab-dot"></span>Certified sworn translator in the Netherlands</div>
        </div>
        <div class="ab-links">
          <a href="mailto:contact@fabverbatim.com">contact@fabverbatim.com</a>
          <a href="tel:+34630573445">+34 630 573 445</a>
          <a href="https://www.linkedin.com/in/fab-verbatim-b005ab268/" target="_blank" rel="noopener">LinkedIn →</a>
        </div>
      </div>
      <div class="ab-text reveal">
        <p class="eyebrow">My Story</p>
        <h2 class="section-title">FAB VERBATIM</h2>
        <p class="ab-p">Languages have been a great passion of mine since I was a child, which has driven me to explore the world and delve into different cultures. Through this passion, I became a sworn translator. Today, with over 30 years' experience and the fact that I'm accredited in Belgium, Spain and the Netherlands for five languages, I bear the important responsibility of ensuring the accuracy and consistency of every translation I produce.</p>
        <p class="ab-p">To me, every day represents a new linguistic and cultural adventure, which commits me to continue exploring, cultivating and improving my translation skills in order to provide accurate and quality translations.</p>
        <p class="ab-p">I am a sworn translator and interpreter, registered in the register of sworn translators in Belgium, Spain, and the Netherlands. Translation of official documents with legalisation and apostille into Spanish, English, French, Dutch and Catalan. Experience in legal, economic-financial, technical and specialised translation within the machinery industry sector.</p>
        <div class="ab-stats">
          <div><span class="abn">30+</span><span class="abl">Years Experience</span></div>
          <div><span class="abn">5</span><span class="abl">Languages</span></div>
          <div><span class="abn">3</span><span class="abl">Countries</span></div>
        </div>
      </div>
    </section>
    <ContactForm lang="en"/>
  </main>
  <Footer lang="en"/>
</Layout>
<style>
  .about-block { display:grid; grid-template-columns:1fr 1.4fr; background:var(--white); }
  .ab-img { padding:5rem 3rem 5rem 4rem; background:var(--cream); border-right:1px solid var(--border); display:flex; flex-direction:column; gap:2rem; }
  .ab-img img { width:100%; max-width:300px; aspect-ratio:1/1; object-fit:cover; object-position:top center; border:3px solid var(--gold); }
  .ab-creds { display:flex; flex-direction:column; gap:0.7rem; }
  .ab-cred { display:flex; align-items:center; gap:0.7rem; font-size:0.82rem; color:var(--navy); }
  .ab-dot { width:8px; height:8px; border-radius:50%; background:var(--gold); flex-shrink:0; }
  .ab-links { display:flex; flex-direction:column; gap:0.5rem; border-top:1px solid var(--border); padding-top:1.5rem; }
  .ab-links a { font-size:0.83rem; color:var(--navy); transition:color 0.2s; }
  .ab-links a:hover { color:var(--gold); }
  .ab-text { padding:5rem 4rem; }
  .ab-p { font-size:0.97rem; font-weight:300; color:#2a2a2a; line-height:1.9; margin-bottom:1.2rem; }
  .ab-stats { display:flex; gap:2.5rem; border-top:1px solid var(--border); padding-top:2rem; margin-top:2rem; flex-wrap:wrap; }
  .ab-stats div { display:flex; flex-direction:column; }
  .abn { font-family:var(--serif); font-size:2.2rem; font-weight:700; color:var(--gold); line-height:1; }
  .abl { font-size:0.68rem; font-weight:500; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); margin-top:0.3rem; }
  @media (max-width:900px) { .about-block { grid-template-columns:1fr; } .ab-img { padding:4rem 1.5rem 3rem; border-right:none; border-bottom:1px solid var(--border); } .ab-text { padding:3rem 1.5rem; } }
</style>
<script>
  const obs = new IntersectionObserver((entries) => { entries.forEach((e,i) => { if(e.isIntersecting) setTimeout(() => e.target.classList.add('visible'), i*60); }); }, {threshold:0.07});
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>
