---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import ContactForm from '../../components/ContactForm.astro';
import Footer from '../../components/Footer.astro';
---
<Layout lang="en" title="Technical Translation Service — Fab Verbatim">
  <Nav lang="en" currentPage="services"/>
  <main>
    <div class="page-hero">
      <div class="page-hero-inner reveal">
        <p class="eyebrow eyebrow--light">Services</p>
        <h1>Technical Translation Service</h1>
        <p>Translations of instruction manuals, tenders, technical specifications and industrial machinery documents.</p>
      </div>
    </div>
    <div class="svc-intro">
      <div class="si-img reveal"><img src="https://images.unsplash.com/photo-1581092160607-ee22621dd758?w=1200&q=80" alt="Technical Translation Service" loading="lazy"/></div>
      <div class="si-text reveal">
        <h2 class="faq-q">What are technical translations?</h2>
        <p class="faq-a">Technical translations convert texts dealing with specialised subjects in technology or engineering from one language to another. These include technical manuals, research papers, product specifications, technical reports and patents. Technical translation goes beyond simple word conversion — it involves clear transmission of complex concepts and specific terminology while maintaining coherence and exactitude of the original content.</p>
        <div class="lang-badges">
          <div class="lang-badge"><span class="lang-badge-dot"></span>Dutch</div>
          <div class="lang-badge"><span class="lang-badge-dot"></span>French</div>
          <div class="lang-badge"><span class="lang-badge-dot"></span>Catalan</div>
          <div class="lang-badge"><span class="lang-badge-dot"></span>Spanish</div>
          <div class="lang-badge"><span class="lang-badge-dot"></span>English</div>
        </div>
      </div>
    </div>
    <div class="faq-block">
      <div class="faq-inner reveal">
        <h2 class="faq-q">What is the purpose of technical translations?</h2>
        <p class="faq-a">Technical translations allow individuals, companies and entities speaking different languages to understand and exchange specialised information. They enable access to technological or engineering knowledge in international contexts, contributing to the spread of technological advances and effective communication in specialised areas. With over 30 years working with industrial machinery manufacturers, I guarantee high-quality technical translations that are accurate, consistent and easy for staff to understand.</p>
      </div>
    </div>
    <section class="values-section">
      <div class="values-header"><p class="eyebrow eyebrow--light">My Values</p><h2 class="section-title section-title--light">Quality, commitment<br/><em>and confidentiality</em></h2></div>
      <div class="value-item"><div class="value-item-icon"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div><div class="value-item-name">Quality</div><div class="value-item-text">Every translation reviewed for accuracy, register and cultural nuance.</div></div>
      <div class="value-item"><div class="value-item-icon"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div><div class="value-item-name">Commitment</div><div class="value-item-text">Your project is treated as a priority from brief to delivery.</div></div>
      <div class="value-item"><div class="value-item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg></div><div class="value-item-name">Accuracy</div><div class="value-item-text">Legal and technical terminology preserved with exactness in every language.</div></div>
      <div class="value-item"><div class="value-item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div><div class="value-item-name">Confidentiality</div><div class="value-item-text">All documents and data handled with complete discretion.</div></div>
      <div class="values-cta-row"><p class="values-text">As an official sworn translator, I have the necessary certification and experience to ensure that your documents are translated accurately and comply with legal requirements.</p><div class="values-btns"><a href="/en/contact" class="btn-gold">Contact →</a><a href="tel:630573445" class="btn-outline--light">Call</a></div></div>
    </section>
    <ContactForm lang="en"/>
  </main>
  <Footer lang="en"/>
</Layout>
<style>
  .svc-intro { display:grid; grid-template-columns:1fr 1fr; background:var(--white); }
  .si-img { overflow:hidden; max-height:520px; }
  .si-img img { width:100%; height:100%; object-fit:cover; }
  .si-text { padding:4rem; display:flex; flex-direction:column; justify-content:center; }
  .faq-inner { max-width:820px; }
  .values-section { background:var(--navy); padding:5rem 4rem; display:grid; grid-template-columns:1fr 1fr; gap:1px; }
  .values-header { grid-column:1/-1; margin-bottom:2rem; }
  .value-item { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.07); }
  .values-cta-row { grid-column:1/-1; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.07); padding:2rem; display:flex; align-items:center; justify-content:space-between; gap:2rem; flex-wrap:wrap; }
  .values-text { font-size:0.92rem; font-weight:300; color:rgba(255,255,255,0.6); line-height:1.85; max-width:600px; }
  .values-btns { display:flex; gap:1rem; flex-shrink:0; }
  .btn-outline--light { display:inline-flex; align-items:center; gap:0.6rem; border:1.5px solid rgba(255,255,255,0.35); color:var(--white); padding:0.9rem 1.8rem; font-family:var(--sans); font-size:0.78rem; font-weight:500; letter-spacing:0.1em; text-transform:uppercase; transition:all 0.22s; border-radius:2px; }
  .btn-outline--light:hover { background:var(--white); color:var(--navy); }
  @media(max-width:900px) { .svc-intro { grid-template-columns:1fr; } .si-img { max-height:280px; } .si-text { padding:3rem 1.5rem; } .values-section { grid-template-columns:1fr; padding:4rem 1.5rem; } .faq-block { padding:3rem 1.5rem; } .values-cta-row { flex-direction:column; align-items:flex-start; } }
</style>
<script>
  const obs = new IntersectionObserver((entries) => { entries.forEach((e,i) => { if(e.isIntersecting) setTimeout(() => e.target.classList.add('visible'), i*60); }); }, {threshold:0.07});
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>
