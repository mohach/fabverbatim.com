---
import Layout from '../layouts/Layout.astro';
import Nav from './Nav.astro';
import ContactForm from './ContactForm.astro';
import Footer from './Footer.astro';

export interface Props {
  lang?: string;
  title: string;
  metaDesc?: string;
  heroTitle: string;
  heroSub: string;
  heroImg: string;
  whatTitle: string;
  whatText: string;
  purposeTitle: string;
  purposeText: string;
  costTitle: string;
  costText: string;
  valuesText: string;
  currentPage?: string;
}

const {
  lang = 'es',
  title,
  metaDesc = '',
  heroTitle,
  heroSub,
  heroImg,
  whatTitle,
  whatText,
  purposeTitle,
  purposeText,
  costTitle,
  costText,
  valuesText,
  currentPage = 'services',
} = Astro.props;

const langBadges = ['Neerlandés', 'Francés', 'Catalán', 'Español', 'Inglés'];
---

<Layout lang={lang} title={title} description={metaDesc}>
  <Nav lang={lang} currentPage={currentPage}/>
  <main>

    <!-- PAGE HERO -->
    <div class="page-hero">
      <div class="page-hero-inner reveal">
        <p class="eyebrow eyebrow--light">Servicios</p>
        <h1>{heroTitle}</h1>
        <p>{heroSub}</p>
      </div>
    </div>

    <!-- HERO IMAGE + WHAT -->
    <div class="svc-intro">
      <div class="svc-intro-img reveal">
        <img src={heroImg} alt={heroTitle} loading="lazy"/>
      </div>
      <div class="svc-intro-text reveal">
        <h2 class="faq-q">{whatTitle}</h2>
        <p class="faq-a" set:html={whatText}/>
        <div class="lang-badges">
          {langBadges.map(l => (
            <div class="lang-badge"><span class="lang-badge-dot"></span>{l}</div>
          ))}
        </div>
      </div>
    </div>

    <!-- PURPOSE -->
    <div class="faq-block">
      <div class="faq-inner reveal">
        <h2 class="faq-q">{purposeTitle}</h2>
        <p class="faq-a" set:html={purposeText}/>
      </div>
    </div>

    <!-- COST -->
    <div class="faq-block" style="background:var(--blue-tint)">
      <div class="faq-inner reveal">
        <h2 class="faq-q">{costTitle}</h2>
        <p class="faq-a" set:html={costText}/>
      </div>
    </div>

    <!-- VALUES -->
    <section class="values-section">
      <div class="values-header">
        <p class="eyebrow eyebrow--light">Mis valores</p>
        <h2 class="section-title section-title--light">Calidad, compromiso<br/><em>y confidencialidad</em></h2>
      </div>
      <div class="value-item">
        <div class="value-item-icon"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <div class="value-item-name">Calidad</div>
        <div class="value-item-text">Cada traducción revisada para garantizar exactitud, registro y matices culturales.</div>
      </div>
      <div class="value-item">
        <div class="value-item-icon"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
        <div class="value-item-name">Compromiso</div>
        <div class="value-item-text">Tu proyecto se trata como una prioridad desde el encargo hasta la entrega.</div>
      </div>
      <div class="value-item">
        <div class="value-item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg></div>
        <div class="value-item-name">Precisión</div>
        <div class="value-item-text">Terminología jurídica y técnica preservada con exactitud en todos los idiomas.</div>
      </div>
      <div class="value-item">
        <div class="value-item-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
        <div class="value-item-name">Confidencialidad</div>
        <div class="value-item-text">Todos los documentos y datos se tratan con total discreción y seguridad.</div>
      </div>
      <div class="values-cta-row">
        <p class="values-text" set:html={valuesText}/>
        <div class="values-btns">
          <a href="#contacto" class="btn-gold">Contactar →</a>
          <a href="tel:630573445" class="btn-outline--light">Llamar</a>
        </div>
      </div>
    </section>

    <ContactForm lang={lang}/>
  </main>
  <Footer lang={lang}/>
</Layout>

<style>
  .svc-intro {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 0; background: var(--white);
  }
  .svc-intro-img { overflow: hidden; max-height: 520px; }
  .svc-intro-img img { width: 100%; height: 100%; object-fit: cover; }
  .svc-intro-text { padding: 4rem; display: flex; flex-direction: column; justify-content: center; }

  .faq-inner { max-width: 820px; }

  .values-section {
    background: var(--navy); padding: 5rem 4rem;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 1px; background-color: var(--navy);
    position: relative;
  }
  .values-header { grid-column: 1 / -1; margin-bottom: 2rem; }
  .value-item { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07); }
  .values-cta-row {
    grid-column: 1 / -1;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    padding: 2rem;
    display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap;
  }
  .values-text { font-size: 0.92rem; font-weight: 300; color: rgba(255,255,255,0.6); line-height: 1.85; max-width: 600px; }
  .values-btns { display: flex; gap: 1rem; flex-shrink: 0; }
  .btn-outline--light {
    display: inline-flex; align-items: center; gap: 0.6rem;
    border: 1.5px solid rgba(255,255,255,0.35); color: var(--white);
    padding: 0.9rem 1.8rem; font-family: var(--sans); font-size: 0.78rem;
    font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    transition: all 0.22s; border-radius: 2px;
  }
  .btn-outline--light:hover { background: var(--white); color: var(--navy); }

  @media (max-width: 900px) {
    .svc-intro { grid-template-columns: 1fr; }
    .svc-intro-img { max-height: 280px; }
    .svc-intro-text { padding: 3rem 1.5rem; }
    .values-section { grid-template-columns: 1fr; padding: 4rem 1.5rem; }
    .values-cta-row { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) setTimeout(() => entry.target.classList.add('visible'), i * 60);
    });
  }, { threshold: 0.07 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
